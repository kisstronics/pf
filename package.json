{
  "name": "personal-finance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && node scripts/prepare-templates.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:registry": "prisma migrate dev --schema=prisma/schema-registry.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.prisma && prisma generate --schema=prisma/schema-registry.prisma",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
